#!/bin/bash
# env-status - 显示当前环境配置状态

PROFILES_DIR="${HOME}/project/C-Link/env-profiles"
CURRENT_FILE="${PROFILES_DIR}/.current"

BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${BLUE}=== Claude Code 环境配置状态 ===${NC}"
echo ""

if [ -f "$CURRENT_FILE" ]; then
    CURRENT_PROFILE=$(cat "$CURRENT_FILE")
    echo -e "${GREEN}当前配置: $CURRENT_PROFILE${NC}"
else
    echo -e "${YELLOW}当前配置: 未设置${NC}"
    CURRENT_PROFILE=""
fi
echo ""

echo "当前会话环境变量:"
echo "  ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL:-<未设置>}"
echo "  ANTHROPIC_AUTH_TOKEN=${ANTHROPIC_AUTH_TOKEN:+<已设置>}"
echo "  ANTHROPIC_DEFAULT_SONNET_MODEL=${ANTHROPIC_DEFAULT_SONNET_MODEL:-<未设置>}"
echo "  ANTHROPIC_DEFAULT_OPUS_MODEL=${ANTHROPIC_DEFAULT_OPUS_MODEL:-<未设置>}"
echo "  ANTHROPIC_DEFAULT_HAIKU_MODEL=${ANTHROPIC_DEFAULT_HAIKU_MODEL:-<未设置>}"
echo ""

echo "可用配置文件:"
python3 << 'PYEOF'
import json
import os
from pathlib import Path

profiles_dir = Path.home() / "project" / "C-Link" / "env-profiles"
current_file = profiles_dir / ".current"
current_profile = current_file.read_text().strip() if current_file.exists() else ""

for f in sorted(profiles_dir.glob("*.json")):
    if f.name == ".current":
        continue
    try:
        config = json.loads(f.read_text())
        name = config.get("name", f.stem)
        desc = config.get("description", "无描述")
        url = config.get("env", {}).get("ANTHROPIC_BASE_URL", "未设置")
        
        marker = "  "
        if name == current_profile:
            marker = " * "
        print(f"    {marker}{name}")
        print(f"        描述: {desc}")
        print(f"        URL: {url}")
        print()
    except:
        pass
PYEOF

echo "提示: 使用 env-switch <profile-name> 切换配置"
