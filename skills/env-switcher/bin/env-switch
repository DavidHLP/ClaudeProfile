#!/bin/bash
# env-switch - 切换 Claude Code 环境配置
# 用法: eval $(env-switch <profile-name>)

PROFILES_DIR="${HOME}/project/C-Link/env-profiles"
CURRENT_FILE="${PROFILES_DIR}/.current"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
    echo "用法: eval \$(env-switch <profile-name>)"
    echo ""
    echo "切换到指定的环境配置文件"
    echo ""
    echo "示例:"
    echo "  eval \$(env-switch minimax)    # 切换到 MiniMax 配置"
    echo "  eval \$(env-switch anthropic)  # 切换到 Anthropic 官方配置"
}

list_profiles() {
    if [ -d "$PROFILES_DIR" ]; then
        for f in "$PROFILES_DIR"/*.json; do
            if [ -f "$f" ]; then
                name=$(basename "$f" .json)
                if [ "$name" != ".current" ]; then
                    echo "  - $name"
                fi
            fi
        done
    fi
}

if [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
    exit 0
fi

PROFILE_NAME="$1"
PROFILE_FILE="${PROFILES_DIR}/${PROFILE_NAME}.json"

if [ ! -f "$PROFILE_FILE" ]; then
    echo -e "${RED}错误: 配置 '$PROFILE_NAME' 不存在${NC}" >&2
    echo "" >&2
    echo "可用配置:" >&2
    list_profiles >&2
    exit 1
fi

# 输出导出命令（用于 eval）
python3 - "$PROFILE_NAME" "$PROFILE_FILE" "$CURRENT_FILE" << 'PYEOF'
import json
import sys

profile_name = sys.argv[1]
profile_file = sys.argv[2]
current_file = sys.argv[3]

with open(profile_file, "r") as f:
    config = json.load(f)

env = config.get("env", {})
for key, value in env.items():
    if value:
        print(f"export {key}='{value}';")

# 更新当前配置
with open(current_file, "w") as f:
    f.write(profile_name)
PYEOF

# 如果是交互式调用（非 eval），显示确认信息
if [ -t 1 ]; then
    echo ""
    echo -e "${GREEN}✓ 已切换到配置: $PROFILE_NAME${NC}"
    echo ""
    echo "当前会话环境变量:"
    echo "  ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL}"
    echo "  ANTHROPIC_DEFAULT_SONNET_MODEL=${ANTHROPIC_DEFAULT_SONNET_MODEL}"
    echo "  ANTHROPIC_DEFAULT_OPUS_MODEL=${ANTHROPIC_DEFAULT_OPUS_MODEL}"
    echo "  ANTHROPIC_DEFAULT_HAIKU_MODEL=${ANTHROPIC_DEFAULT_HAIKU_MODEL}"
    echo ""
    echo -e "${YELLOW}注意: 这些变更仅在当前会话有效${NC}"
fi
