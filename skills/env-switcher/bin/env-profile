#!/bin/bash
# env-profile - 管理环境配置文件

PROFILES_DIR="${HOME}/project/C-Link/env-profiles"
CURRENT_FILE="${PROFILES_DIR}/.current"

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

mkdir -p "$PROFILES_DIR"

usage() {
    echo "用法: env-profile <command> [args]"
    echo ""
    echo "命令:"
    echo "  list                    列出所有可用配置"
    echo "  create <name>          创建新配置"
    echo "  delete <name>          删除配置"
    echo "  edit <name>            编辑配置"
    echo "  show <name>            显示配置详情"
}

cmd_list() {
    echo -e "${BLUE}可用配置文件:${NC}"
    echo ""
    python3 << 'PYEOF'
import json
from pathlib import Path

profiles_dir = Path.home() / "project" / "C-Link" / "env-profiles"
current_file = profiles_dir / ".current"
current_profile = current_file.read_text().strip() if current_file.exists() else ""

count = 0
for f in sorted(profiles_dir.glob("*.json")):
    if f.name == ".current":
        continue
    count += 1
    try:
        config = json.loads(f.read_text())
        name = config.get("name", f.stem)
        desc = config.get("description", "无描述")
        url = config.get("env", {}).get("ANTHROPIC_BASE_URL", "未设置")
        
        marker = "  "
        if name == current_profile:
            marker = " * "
        print(f"  {marker}{name}")
        print(f"      描述: {desc}")
        print(f"      URL: {url}")
        print()
    except:
        pass

if count == 0:
    print("  (无配置文件)")
    print()
print(f"共 {count} 个配置")
PYEOF
}

cmd_create() {
    local name="$1"
    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请指定配置名称${NC}"
        exit 1
    fi
    
    local file="${PROFILES_DIR}/${name}.json"
    if [ -f "$file" ]; then
        echo -e "${RED}错误: 配置 '$name' 已存在${NC}"
        exit 1
    fi
    
    cat > "$file" << EOF
{
  "name": "$name",
  "description": "自定义配置",
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.anthropic.com",
    "ANTHROPIC_AUTH_TOKEN": "your-api-token-here",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-20250514",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-20250514",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-20250514"
  }
}
EOF
    
    echo -e "${GREEN}✓ 配置 '$name' 已创建${NC}"
    echo "文件: $file"
}

cmd_delete() {
    local name="$1"
    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请指定配置名称${NC}"
        exit 1
    fi
    
    local file="${PROFILES_DIR}/${name}.json"
    if [ ! -f "$file" ]; then
        echo -e "${RED}错误: 配置 '$name' 不存在${NC}"
        exit 1
    fi
    
    rm "$file"
    echo -e "${GREEN}✓ 配置 '$name' 已删除${NC}"
}

cmd_edit() {
    local name="$1"
    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请指定配置名称${NC}"
        exit 1
    fi
    
    local file="${PROFILES_DIR}/${name}.json"
    if [ ! -f "$file" ]; then
        echo -e "${RED}错误: 配置 '$name' 不存在${NC}"
        exit 1
    fi
    
    ${EDITOR:-vi} "$file"
    echo -e "${GREEN}✓ 配置 '$name' 已更新${NC}"
}

cmd_show() {
    local name="$1"
    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请指定配置名称${NC}"
        exit 1
    fi
    
    local file="${PROFILES_DIR}/${name}.json"
    if [ ! -f "$file" ]; then
        echo -e "${RED}错误: 配置 '$name' 不存在${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}配置: $name${NC}"
    echo ""
    cat "$file"
}

case "$1" in
    list)
        cmd_list
        ;;
    create)
        cmd_create "$2"
        ;;
    delete)
        cmd_delete "$2"
        ;;
    edit)
        cmd_edit "$2"
        ;;
    show)
        cmd_show "$2"
        ;;
    *)
        usage
        exit 0
        ;;
esac
